<?xml version="1.0" encoding="utf-8"?>
<!-- ═══════════════════════════════════════════════════════════════
     Main Activity — Redesigned mobile-first gesture control UI
     Compact camera preview + status + gesture label + action bar
     ═══════════════════════════════════════════════════════════════ -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- ═══ Header Bar ════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/headerBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Status dot (animated) -->
        <View
            android:id="@+id/statusDot"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@color/status_active" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="ACTIVE"
            android:textColor="@color/status_active"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginStart="10dp" />

        <!-- Settings button -->
        <TextView
            android:id="@+id/btnSettings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚙️"
            android:textSize="22sp"
            android:padding="8dp"
            android:background="?android:attr/selectableItemBackgroundBorderless" />
    </LinearLayout>

    <!-- ═══ Camera Preview Card ═══════════════════════════════════ -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cameraCard"
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="8dp"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="@color/bg_card"
        app:cardElevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/headerBar">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.camera.view.PreviewView
                android:id="@+id/previewView"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <!-- Camera label overlay -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📷 Front Camera"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:padding="8dp"
                android:background="#66000000"
                android:layout_gravity="bottom|start" />
        </FrameLayout>
    </androidx.cardview.widget.CardView>

    <!-- ═══ Current Gesture Display ═══════════════════════════════ -->
    <LinearLayout
        android:id="@+id/gestureDisplay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp"
        app:layout_constraintTop_toBottomOf="@id/cameraCard"
        app:layout_constraintBottom_toTopOf="@id/cheatSheetCard">

        <TextView
            android:id="@+id/gestureEmoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🖐"
            android:textSize="48sp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/gestureText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Waiting for hand…"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/gestureSubtext"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Show your hand to the camera"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- ═══ Gesture Cheat Sheet Card ══════════════════════════════ -->
    <LinearLayout
        android:id="@+id/cheatSheetCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bg_card"
        android:padding="16dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintBottom_toTopOf="@id/bottomBar">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GESTURES"
            android:textColor="@color/accent"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/cheatSheetText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✊ Fist → Pause    ☝️ Index → Cursor    ☝✌ Both → Scroll ↑\n🖕 Mid up → Scroll ↓    ✌️↔ Spread → Zoom    🤙 Pinch → Long Press"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:lineSpacingExtra="4dp" />
    </LinearLayout>

    <!-- ═══ Bottom Action Bar ═════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="12dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/accessibilityBtn"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Enable Service"
            android:textSize="12sp"
            android:textAllCaps="false"
            android:backgroundTint="@color/primary"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/toggleBtn"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="⏸ Pause"
            android:textSize="12sp"
            android:textAllCaps="false"
            android:backgroundTint="@color/bg_card_elevated"
            android:layout_marginStart="8dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
